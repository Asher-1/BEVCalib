    {
      "type": "rectangle",
      "id": "fusion_df",
      "x": 30,
      "y": 850,
      "width": 1230,
      "height": 187,
      "strokeColor": "#6d28d9",
      "backgroundColor": "#ddd6fe",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 670003,
