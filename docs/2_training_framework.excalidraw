    {
      "type": "text",
      "id": "amp_text",
      "x": 430,
      "y": 678,
      "width": 280,
      "height": 161,
      "text": "AMP (Mixed Precision)\n\namp_dtype = torch.float16\nscaler = GradScaler(enabled=True)\n\n流程:\n  autocast(fp16) → forward\n  scaler.scale(loss).backward()\n  scaler.unscale_(optimizer)\n  clip_grad_norm_(max=35.0)\n  scaler.step → scaler.update",
      "originalText": "AMP (Mixed Precision)\n\namp_dtype = torch.float16\nscaler = GradScaler(enabled=True)\n\n流程:\n  autocast(fp16) → forward\n  scaler.scale(loss).backward()\n  scaler.unscale_(optimizer)\n  clip_grad_norm_(max=35.0)\n  scaler.step → scaler.update",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
