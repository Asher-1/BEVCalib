    {
      "type": "text",
      "id": "ddp_text",
      "x": 40,
      "y": 678,
      "width": 340,
      "height": 147,
      "text": "DDP (DistributedDataParallel)\n\nbackend='nccl', timeout=30min\nDDP(model, device_ids=[local_rank],\n    find_unused_parameters=True)\n\n单节点: torchrun --standalone --nproc_per_node=N\n多节点: torchrun --nnodes=M --rdzv_backend=c10d\nSLURM: 自动检测 SLURM_NNODES/NODEID\nK8s: MASTER_ADDR/RANK/WORLD_SIZE from env",
      "originalText": "DDP (DistributedDataParallel)\n\nbackend='nccl', timeout=30min\nDDP(model, device_ids=[local_rank],\n    find_unused_parameters=True)\n\n单节点: torchrun --standalone --nproc_per_node=N\n多节点: torchrun --nnodes=M --rdzv_backend=c10d\nSLURM: 自动检测 SLURM_NNODES/NODEID\nK8s: MASTER_ADDR/RANK/WORLD_SIZE from env",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
