    {
      "type": "text",
      "id": "cuda_ext_text",
      "x": 40,
      "y": 948,
      "width": 300,
      "height": 106,
      "text": "bev_pool_ext (自定义 CUDA)\n\nimg_branch/bev_pool/\n  bev_pool.py + bev_pool_cuda.cu\n  QuickCumsum / QuickCumsumCudaV2\n  cumsum-based scatter\n  python setup.py build_ext --inplace",
      "originalText": "bev_pool_ext (自定义 CUDA)\n\nimg_branch/bev_pool/\n  bev_pool.py + bev_pool_cuda.cu\n  QuickCumsum / QuickCumsumCudaV2\n  cumsum-based scatter\n  python setup.py build_ext --inplace",
