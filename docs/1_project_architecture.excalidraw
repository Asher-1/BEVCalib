    {
      "type": "text",
      "id": "pc_branch_text",
      "x": 320,
      "y": 318,
      "width": 260,
      "height": 100,
      "text": "PC Branch (Lidar2BEV)\n\nPointToVoxel [spconv]\n  → SparseEncoder 3D (16→128)\n  → Z 压缩 + ProjectionHead\n→ (B, 128, 100, 100)",
      "originalText": "PC Branch (Lidar2BEV)\n\nPointToVoxel [spconv]\n  → SparseEncoder 3D (16→128)\n  → Z 压缩 + ProjectionHead\n→ (B, 128, 100, 100)",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
